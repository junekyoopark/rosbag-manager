# Required
POSTGRES_PASSWORD=changeme
PUBLIC_HOST=192.168.1.100        # or your domain/IP

# Auth (required)
SECRET_KEY=replace-with-output-of--python3-c-import-secrets-print-secrets.token_hex-32
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme  # only used on first boot; remove after first login

# Optional overrides
DATA_DIR=./data                  # Host path for bag_data volume
MAX_UPLOAD_SIZE_GB=50
RERUN_VERSION=0.32.0

# S3 storage (optional — leave empty for local)
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Celery worker concurrency
WORKER_CONCURRENCY=2

# Flower (Celery monitor) auth — set to restrict access
# FLOWER_BASIC_AUTH=admin:changeme
