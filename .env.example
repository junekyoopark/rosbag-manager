# Required
POSTGRES_PASSWORD=changeme
PUBLIC_HOST=192.168.1.100        # LAN IP for HTTP, or your domain for HTTPS

# HTTPS / Let's Encrypt (required only for HTTPS deployment)
DOMAIN=yourdomain.com            # must match your DNS A record
CERTBOT_EMAIL=admin@yourdomain.com

# Auth (required)
SECRET_KEY=replace-with-output-of--python3-c-import-secrets-print-secrets.token_hex-32

# Initial admin — optional. If omitted, a setup wizard runs on first visit.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=changeme

# Optional overrides
DATA_DIR=./data                  # Host path for bag_data volume
MAX_UPLOAD_SIZE_GB=50
RERUN_VERSION=0.32.0

# S3 storage (optional — leave empty for local)
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Celery worker concurrency
WORKER_CONCURRENCY=2

# Flower (Celery monitor) auth — set to restrict access
# FLOWER_BASIC_AUTH=admin:changeme

# Robot WebSocket proxy for Lichtblick live view over internet
# Set to the robot's IP/hostname (must be reachable from this server).
# Then in Lichtblick: Open connection → WebSocket → ws(s)://<server>/robot-ws
# ROBOT_WS_HOST=192.168.1.50
